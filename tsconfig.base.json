{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@postgres/*": ["packages/postgres/src/*"],
      "@mongo/*": ["packages/mongo/src/*"],
      "@redis/*": ["packages/redis/src/*"],
      "@rabbitmq/*": ["packages/rabbitmq/src/*"]
    }
  }
}
