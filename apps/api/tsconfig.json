{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",       // Move the root up to the monorepo base
    "baseUrl": ".",           // Keeps path resolution relative to this file
    "types": ["node", "express"],
    "paths": {
      "@shared/*": ["../../packages/shared/src/*"],
      "@prisma/client": ["../../packages/postgres/generated/prisma/client"]
    }
  },
  "include": [
    "src", 
    "../../packages/postgres/generated/prisma/client",
    "../../packages/postgres/src"
  ]
}
