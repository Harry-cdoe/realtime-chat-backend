{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "baseUrl": ".",
    "typeRoots": [
      "../../node_modules/@types", 
      "./src/types" 
    ],
    "types": ["node", "express"],
    "paths": {
      "@shared/*": ["../../packages/shared/src/*"],
      "@prisma/client": ["../../packages/postgres/generated/prisma/client"]
    }
  },
  "include": [
    "src/**/*", // Matches your source and your .d.ts files
    "../../packages/postgres/generated/prisma/client",
    "../../packages/postgres/src"
  ]
}
